{
  "compilerOptions": {
    "target": "ESNext",
    "module": "Node16",
    "moduleResolution": "Node16",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "types": ["node"],
    "lib": ["ESNext", "DOM"]
  },
  "include": [
    "playwright.config.ts",
    "tests/**/*.ts",
    "fixtures/**/*.ts",
    "pages/**/*.ts"
  ]
}
